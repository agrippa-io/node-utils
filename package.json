{
  "name": "@agrippa-io/node-utils",
  "version": "1.0.9",
  "description": "NodeJS Utils",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "node",
    "utils"
  ],
  "author": "Agrippa Development Team",
  "license": "MIT",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^2.12.0",
    "@types/node": "^22.19.19",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "change-case": "^4.1.2"
  }
}
